## Step 3: Event Labeling (Survival Analysis Target)

This step creates the target variable for the Cox Proportional Hazards model by identifying customers who experienced a **sustained 3-month decline** in category breadth — our definition of "wallet share erosion event."
# ============================================================================
# STEP 3: EVENT LABELING (SURVIVAL ANALYSIS TARGET)
# ============================================================================
# For each customer, using the last 6 months of category breadth scores:
#   - EVENT = 1 if breadth declined for 3 consecutive months (strict: each < previous)
#   - EVENT = 0 if no such sustained decline (censored observation)
#   - event_time = months observed before event or end of window
# ============================================================================

# Get the list of all months in our observation window
all_months = (
    df_monthly_breadth
    .select("year_month")
    .distinct()
    .orderBy("year_month")
    .collect()
)
all_months_list = [row["year_month"] for row in all_months]
print(f"Months in observation window: {all_months_list}")

# We'll use the last 6 months for event detection
if len(all_months_list) >= 6:
    event_months = all_months_list[-6:]
else:
    event_months = all_months_list
print(f"Event observation months: {event_months}")

# --------------------------------------------------------------------------
# Pivot category breadth scores to wide format for sequential analysis
# --------------------------------------------------------------------------
df_breadth_pivot = (
    df_monthly_breadth
    .filter(F.col("year_month").isin(event_months))
    .groupBy("customer_id")
    .pivot("year_month")
    .agg(F.first("breadth_score"))
)

print(f"\nCustomers with data in event window: {df_breadth_pivot.count():,}")
df_breadth_pivot.show(5, truncate=False)

# --------------------------------------------------------------------------
# Convert to pandas for sequential decline detection
# --------------------------------------------------------------------------
df_breadth_pd = df_breadth_pivot.toPandas()

breadth_cols = [col for col in df_breadth_pd.columns if col != 'customer_id']
breadth_cols = sorted(breadth_cols)
print(f"Breadth columns for analysis: {breadth_cols}")

# Forward fill then fill remaining NaN with 0 (customer did not shop that month)
df_breadth_pd[breadth_cols] = df_breadth_pd[breadth_cols].ffill(axis=1).fillna(0)

# --------------------------------------------------------------------------
# Detect 3-month consecutive decline
# --------------------------------------------------------------------------
def detect_sustained_decline(row, breadth_cols):
    """
    Detect if customer has 3 consecutive months of strictly declining breadth.
    Returns: (event_flag, event_time)
    """
    values = [row[col] for col in breadth_cols]
    consecutive_declines = 0

    for i in range(1, len(values)):
        if values[i] < values[i - 1]:
            consecutive_declines += 1
            if consecutive_declines >= 3:
                return (1, i + 1)
        else:
            consecutive_declines = 0

    return (0, len(values))

results = df_breadth_pd.apply(
    lambda row: detect_sustained_decline(row, breadth_cols),
    axis=1
)
df_breadth_pd['event_flag'] = [r[0] for r in results]
df_breadth_pd['event_time'] = [r[1] for r in results]

# --------------------------------------------------------------------------
# Summary statistics
# --------------------------------------------------------------------------
event_counts = df_breadth_pd['event_flag'].value_counts()
print(f"\n{'='*60}")
print("EVENT LABELING SUMMARY")
print(f"{'='*60}")
print(f"Total customers labeled: {len(df_breadth_pd):,}")
print(f"Event (sustained decline): {event_counts.get(1, 0):,} ({event_counts.get(1, 0)/len(df_breadth_pd)*100:.1f}%)")
print(f"Censored (no event yet): {event_counts.get(0, 0):,} ({event_counts.get(0, 0)/len(df_breadth_pd)*100:.1f}%)")
print(f"\nEvent time distribution:")
print(df_breadth_pd.groupby('event_flag')['event_time'].describe())

