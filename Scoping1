## Step 5: Cox Proportional Hazards Model

This step trains the survival analysis model that estimates each customer's risk of experiencing the "category consolidation" event based on their behavioral features.
# ============================================================================
# STEP 5: COX PROPORTIONAL HAZARDS MODEL
# ============================================================================
# Train Cox PH model using lifelines library.
# Features now include category-wise supermarket breadth, seasonality-aware
# recent-vs-prior quarter comparisons, activity coverage, and concentration.
# Duration: event_time (months until event or censoring)
# Event: event_flag (1 = consolidation event, 0 = censored)
# ============================================================================

# Define feature columns for the model
# Feature set v3 — changes from v2:
#   ADDED (Step 4G momentum features):
#     consecutive_decline_months, last_month_breadth_change,
#     breadth_acceleration, pct_months_declining
#   REMOVED (p > 0.3, statistically insignificant — adding noise):
#     breadth_current (p=0.631), breadth_volatility (p=0.522),
#     atv (p=0.582), breadth_recent_3m_avg (p=0.722),
#     weekend_txn_share (p=0.284), loyalty_tenure_months (p=0.938),
#     ATV_last_6_month (p=0.532)
feature_columns = [
    # Breadth trajectory (level + trend)
    'breadth_slope',
    'breadth_peak',
    'breadth_drop_pct',
    'months_since_peak',
    # Breadth momentum / shape — NEW (most predictive group)
    'consecutive_decline_months',      # mirrors event definition directly
    'last_month_breadth_change',       # most recent directional signal
    'breadth_acceleration',            # is decline speeding up?
    'pct_months_declining',            # fraction of months in decline
    # Spend signals — 2 orthogonal only
    'avg_monthly_spend',
    'spend_recent_vs_prev_3m_ratio',
    # Activity & concentration
    'active_month_ratio',
    'breadth_prev_3m_avg',
    'breadth_recent_vs_prev_3m_ratio',
    'top_category_spend_share',
    # Customer enriched signals
    'recency',
    'maturity',
    'decrease_cohort',
    'RPC_last_6_month',
    'sale_decile'
]

# --------------------------------------------------------------------------
# Guard: sanitize feature matrix before fitting
# --------------------------------------------------------------------------
df_model_data_clean = df_model_data.replace([np.inf, -np.inf], np.nan)

feature_null_rates = df_model_data_clean[feature_columns].isnull().mean()
zero_var_cols = [c for c in feature_columns if df_model_data_clean[c].nunique(dropna=True) <= 1]
high_null_cols = feature_null_rates[feature_null_rates > 0.30].index.tolist()
drop_cols = list(set(zero_var_cols + high_null_cols))

if drop_cols:
    print(f"Dropping {len(drop_cols)} column(s) — zero variance or >30% null: {drop_cols}")

clean_feature_columns = [c for c in feature_columns if c not in drop_cols]

# Fill remaining NaN with median (more robust than 0 for skewed distributions)
df_model_data_clean[clean_feature_columns] = (
    df_model_data_clean[clean_feature_columns]
    .apply(lambda col: col.fillna(col.median()))
)

# Scale features to unit variance to help Cox Newton-Raphson converge
from sklearn.preprocessing import StandardScaler as _SS
_scaler = _SS()
df_model_data_clean[clean_feature_columns] = _scaler.fit_transform(
    df_model_data_clean[clean_feature_columns]
)

# Build the final modeling matrix
model_cols = clean_feature_columns + ['event_time', 'event_flag']
df_cox = df_model_data_clean[model_cols].copy()
df_cox['event_time'] = df_cox['event_time'].clip(lower=1)

print(f"Training data shape: {df_cox.shape}")
print(f"Event rate: {df_cox['event_flag'].mean()*100:.1f}%")
print(f"Features used: {clean_feature_columns}")
print(f"\nNull check (should all be 0):")
print(df_cox[clean_feature_columns].isnull().sum()[lambda s: s > 0])

# --------------------------------------------------------------------------
# Fit Cox Proportional Hazards Model
# --------------------------------------------------------------------------
print("\n" + "="*60)
print("FITTING COX PROPORTIONAL HAZARDS MODEL")
print("="*60)

# penalizer 0.5 → 0.2: features are now cleaner (noise removed, momentum added).
# 0.5 was over-shrinking real effects (all coefficients were capped at ±0.07).
cph = CoxPHFitter(penalizer=0.2)

cph.fit(
    df_cox,
    duration_col='event_time',
    event_col='event_flag',
    show_progress=True
)

# Print model summary
print("\n" + "="*60)
print("MODEL SUMMARY")
print("="*60)
cph.print_summary(decimals=3, columns=['coef', 'exp(coef)', 'p', 'coef lower 95%', 'coef upper 95%'])

# --------------------------------------------------------------------------
# Model Performance Metrics
# --------------------------------------------------------------------------
print("\n" + "="*60)
print("MODEL PERFORMANCE")
print("="*60)

raw_concordance = cph.concordance_index_
# concordance_index_ = concordance_index(T, -predicted_hazard, E)
# If raw < 0.5 the model's polarity is inverted; effective C = 1 - raw.
concordance = raw_concordance if raw_concordance >= 0.5 else 1.0 - raw_concordance
if raw_concordance < 0.5:
    print(f"Note: raw concordance_index_ = {raw_concordance:.3f} (< 0.5 — scores inverted).")
    print(f"      Effective C-index after inversion = {concordance:.3f}")
else:
    print(f"Concordance Index: {concordance:.3f}")
print(f"  - Interpretation: {concordance:.1%} of customer pairs are correctly ranked by risk")
print(f"  - Benchmark: 0.50 = random guessing, 0.70+ = good, 0.80+ = excellent")

if concordance >= 0.65:
    print("  Model meets target threshold (>= 0.65)")
else:
    print("  Model below target threshold (0.65). Consider additional features.")

# --------------------------------------------------------------------------
# Visualizations
# --------------------------------------------------------------------------
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

ax1 = axes[0]
cph.plot(ax=ax1)
ax1.set_title('Feature Coefficients (Log Hazard Ratios)\nPositive = Increases Risk, Negative = Decreases Risk', fontsize=10)
ax1.axvline(x=0, color='red', linestyle='--', alpha=0.5)
ax1.set_xlabel('Coefficient (log hazard ratio)')

ax2 = axes[1]
cph.plot_partial_effects_on_outcome(
    covariates='breadth_slope',
    values=[-0.5, 0, 0.5],
    ax=ax2,
    cmap='coolwarm'
)
ax2.set_title('Survival Curves by Breadth Slope\n(Lower slope = Higher risk)', fontsize=10)
ax2.set_xlabel('Time (months)')
ax2.set_ylabel('Survival Probability (no event)')
ax2.legend(title='breadth_slope', labels=['Declining (-0.5)', 'Stable (0)', 'Growing (+0.5)'])

plt.tight_layout()
plt.show()

# --------------------------------------------------------------------------
# Top Risk Factors
# --------------------------------------------------------------------------
print("\n" + "="*60)
print("TOP RISK FACTORS (by absolute coefficient magnitude)")
print("="*60)

coef_df = cph.summary[['coef', 'exp(coef)', 'p']].copy()
coef_df['abs_coef'] = coef_df['coef'].abs()
coef_df = coef_df.sort_values('abs_coef', ascending=False)

for idx, row in coef_df.head(8).iterrows():
    direction = "increases" if row['coef'] > 0 else "decreases"
    hr = row['exp(coef)']
    print(f"  {idx}: {direction} risk (HR={hr:.2f}, p={row['p']:.3f})")

print("\nCandidate next improvements to test:")
print("  1. Category entropy / concentration trend over time")
print("  2. Promo sensitivity and discount share in supermarket baskets")
print("  3. Store-switching frequency across regions / formats")
print("  4. Weekly cadence features and holiday / Ramadan calendar flags")
print("  5. Time-based validation on older scoring months for stability")

