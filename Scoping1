## Step 4: Feature Engineering

This step creates the predictor variables for the Cox model by engineering features that capture both the **level** and **direction of change** in customer behavior.
# ============================================================================
# STEP 4: FEATURE ENGINEERING  (Optimised — Pure PySpark, no pandas loop)
# ============================================================================
# All trajectory features are computed as distributed Spark aggregations.
# Category breadth is measured at category_id level within SUPER MARKET only.
# Seasonality is handled using rolling quarter-over-quarter comparisons,
# active-month coverage, weekend shopping share, and category concentration.
# ============================================================================

# --------------------------------------------------------------------------
# 4A: OLS slope constants for the N-point monthly series
# --------------------------------------------------------------------------
N = len(event_months)
SUM_X = float(N * (N + 1) / 2)
SUM_XX = float(N * (N + 1) * (2 * N + 1) / 6)
DENOM = float(N * SUM_XX - SUM_X ** 2)

print(f"Feature window: {N} months | OLS denominator: {DENOM}")
print(f"Months: {event_months}")

# --------------------------------------------------------------------------
# 4B: Build a complete customer-month panel for the feature window
# --------------------------------------------------------------------------
# This makes slope and recent-vs-prior comparisons robust even when customers
# skipped some months. Missing months are treated as zero supermarket activity.
feature_month_rows = [(m,) for m in sorted(event_months)]
df_feature_months = spark.createDataFrame(feature_month_rows, ["year_month"])

df_customer_base = df_customer_attrs.select("customer_id").dropDuplicates(["customer_id"])

df_monthly_complete = (
    df_customer_base
    .crossJoin(df_feature_months)
    .join(
        df_monthly_breadth.filter(F.col("year_month").isin(event_months)),
        on=["customer_id", "year_month"],
        how="left"
    )
    .fillna({"breadth_score": 0.0, "total_spend": 0.0, "visit_count": 0.0})
)

print(f"Complete customer-month panel: {df_monthly_complete.count():,} rows")

# --------------------------------------------------------------------------
# 4C: Add chronological month index to each customer-month row
# --------------------------------------------------------------------------
w_order = Window.partitionBy("customer_id").orderBy("year_month")

df_monthly_indexed = (
    df_monthly_complete
    .withColumn("midx", F.row_number().over(w_order).cast("double"))
    .withColumn("xi_b", F.col("midx") * F.col("breadth_score").cast("double"))
    .withColumn("xi_s", F.col("midx") * F.col("total_spend"))
    .withColumn("active_month_flag", F.when(F.col("total_spend") > 0, F.lit(1.0)).otherwise(F.lit(0.0)))
)

# --------------------------------------------------------------------------
# 4D: Current breadth and peak timing
# --------------------------------------------------------------------------
last_month = sorted(event_months)[-1]
df_breadth_current = (
    df_monthly_indexed
    .filter(F.col("year_month") == last_month)
    .select(
        "customer_id",
        F.col("breadth_score").cast("double").alias("breadth_current")
    )
)

w_peak = Window.partitionBy("customer_id").orderBy(
    F.desc("breadth_score"), F.desc("midx")
)
df_peak_timing = (
    df_monthly_indexed
    .withColumn("pk_rank", F.row_number().over(w_peak))
    .filter(F.col("pk_rank") == 1)
    .select(
        "customer_id",
        (F.lit(float(N)) - F.col("midx")).alias("months_since_peak")
    )
)

# --------------------------------------------------------------------------
# 4E: Seasonality-aware transactional features
# --------------------------------------------------------------------------
df_txn_event_window = df_txn_supermarket.filter(F.col("year_month").isin(event_months))

# Share of supermarket spend concentrated in the customer's top category.
df_category_concentration = (
    df_txn_event_window
    .groupBy("customer_id", "category_id")
    .agg(F.sum("net_amount").alias("category_spend"))
    .groupBy("customer_id")
    .agg((F.max("category_spend") / F.sum("category_spend")).alias("top_category_spend_share"))
)

# Weekend shopping share captures recurring timing behavior.
# UAE retail weekends are modeled as Saturday/Sunday.
df_timing_features = (
    df_txn_event_window
    .withColumn("is_weekend", F.when(F.dayofweek("transaction_date").isin([1, 7]), F.lit(1.0)).otherwise(F.lit(0.0)))
    .groupBy("customer_id")
    .agg(F.avg("is_weekend").alias("weekend_txn_share"))
)

# --------------------------------------------------------------------------
# 4F: Main distributed aggregation — all features in one Spark pass
# --------------------------------------------------------------------------
df_features_spark = (
    df_monthly_indexed
    .groupBy("customer_id")
    .agg(
        F.max(F.col("breadth_score").cast("double")).alias("breadth_peak"),
        F.stddev_samp("breadth_score").alias("breadth_volatility"),
        F.avg("total_spend").alias("avg_monthly_spend"),
        F.avg("visit_count").alias("avg_visit_count"),
        F.avg("active_month_flag").alias("active_month_ratio"),
        F.avg(F.when(F.col("midx") <= N - 3, F.col("breadth_score"))).alias("breadth_prev_3m_avg"),
        F.avg(F.when(F.col("midx") > N - 3, F.col("breadth_score"))).alias("breadth_recent_3m_avg"),
        F.avg(F.when(F.col("midx") <= N - 3, F.col("total_spend"))).alias("spend_prev_3m_avg"),
        F.avg(F.when(F.col("midx") > N - 3, F.col("total_spend"))).alias("spend_recent_3m_avg"),
        F.sum(F.col("breadth_score").cast("double")).alias("sy_b"),
        F.sum("xi_b").alias("sxy_b"),
        F.sum("total_spend").alias("sy_s"),
        F.sum("xi_s").alias("sxy_s")
    )
    .withColumn(
        "breadth_slope",
        (F.lit(N) * F.col("sxy_b") - F.lit(SUM_X) * F.col("sy_b")) / F.lit(DENOM)
    )
    .withColumn(
        "spend_slope",
        (F.lit(N) * F.col("sxy_s") - F.lit(SUM_X) * F.col("sy_s")) / F.lit(DENOM)
    )
    .withColumn(
        "atv",
        F.when(F.col("avg_visit_count") > 0, F.col("avg_monthly_spend") / F.col("avg_visit_count")).otherwise(F.lit(0.0))
    )
    .withColumn(
        "breadth_recent_vs_prev_3m_ratio",
        F.when(F.col("breadth_prev_3m_avg") > 0, F.least(F.col("breadth_recent_3m_avg") / F.col("breadth_prev_3m_avg"), F.lit(5.0)))
         .when(F.col("breadth_recent_3m_avg") > 0, F.lit(2.0))
         .otherwise(F.lit(1.0))
    )
    .withColumn(
        "spend_recent_vs_prev_3m_ratio",
        F.when(F.col("spend_prev_3m_avg") > 0, F.least(F.col("spend_recent_3m_avg") / F.col("spend_prev_3m_avg"), F.lit(5.0)))
         .when(F.col("spend_recent_3m_avg") > 0, F.lit(2.0))
         .otherwise(F.lit(1.0))
    )
    .drop("sy_b", "sxy_b", "sy_s", "sxy_s", "avg_visit_count")
)

# Join current breadth, peak timing, and seasonality-aware features
# Also attach the customer's dominant supermarket region in the last 90 days.
df_features_spark = (
    df_features_spark
    .join(df_breadth_current, "customer_id", "left")
    .join(df_peak_timing, "customer_id", "left")
    .join(df_category_concentration, "customer_id", "left")
    .join(df_timing_features, "customer_id", "left")
    .join(df_primary_region, "customer_id", "left")
    .withColumn("breadth_current", F.coalesce(F.col("breadth_current"), F.lit(0.0)))
    .withColumn("months_since_peak", F.coalesce(F.col("months_since_peak"), F.lit(0.0)))
    .withColumn(
        "breadth_drop_pct",
        F.when(
            F.col("breadth_peak") > 0,
            F.greatest((F.col("breadth_peak") - F.col("breadth_current")) / F.col("breadth_peak") * 100.0, F.lit(0.0))
        ).otherwise(F.lit(0.0))
    )
    .fillna({
        "breadth_volatility": 0.0,
        "breadth_slope": 0.0,
        "spend_slope": 0.0,
        "avg_monthly_spend": 0.0,
        "atv": 0.0,
        "breadth_peak": 0.0,
        "active_month_ratio": 0.0,
        "breadth_prev_3m_avg": 0.0,
        "breadth_recent_3m_avg": 0.0,
        "spend_prev_3m_avg": 0.0,
        "spend_recent_3m_avg": 0.0,
        "breadth_recent_vs_prev_3m_ratio": 1.0,
        "spend_recent_vs_prev_3m_ratio": 1.0,
        "top_category_spend_share": 0.0,
        "weekend_txn_share": 0.0,
        "region_name": "Unknown"
    })
)

spark_count = df_features_spark.count()
print(f"\nSpark features computed: {spark_count:,} customers (fully distributed)")
display(
    df_features_spark.select(
        F.round(F.avg("breadth_slope"), 4).alias("avg_breadth_slope"),
