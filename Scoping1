        F.round(F.avg("top_category_spend_share"), 3).alias("avg_top_category_spend_share")
    )
)

# --------------------------------------------------------------------------
# 4G: Single toPandas() on the compact feature table + enrich with attrs
# --------------------------------------------------------------------------
df_customer_features = df_features_spark.toPandas()
df_customer_features["customer_id"] = df_customer_features["customer_id"].astype(str)

