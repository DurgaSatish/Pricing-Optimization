## Step 2: Monthly Category Breadth Computation

This step aggregates raw transactions into a customer-month view that captures:
- **Breadth Score**: How many distinct departments the customer purchased from
- **Total Spend**: Sum of net amounts for the month
- **Visit Count**: Number of distinct transactions (store visits)
# ============================================================================
# STEP 2: MONTHLY CATEGORY BREADTH COMPUTATION
# ============================================================================
# For each customer-month, compute category-wise breadth within SUPER MARKET:
#   - breadth_score: COUNT(DISTINCT category_id)
#   - total_spend: SUM(net_amount)
#   - visit_count: COUNT(DISTINCT transaction_id)
#   - top_category: most frequent category that month
# Also derive each customer's primary region_name from the last 90 days of
# supermarket transactions using the max transaction count rule.
# ============================================================================

# Join transactions with materials, restrict to supermarket, and enrich stores
# Category breadth is intentionally computed at category_id level, not department_id.
df_txn_supermarket = (
    df_transactions
    .join(
        df_materials.select(
            "product_id",
            "category_id",
            "category_name",
            "department_class_id",
            "department_class_name"
        ),
        on="product_id",
        how="inner"
    )
    .filter(F.col("department_class_name") == SUPERMARKET_CLASS)
    .join(df_stores, on="store_id", how="left")
    .withColumn("year_month", F.date_format(F.col("transaction_date"), "yyyy-MM"))
)

print(f"Supermarket transactions with category mapping: {df_txn_supermarket.count():,} rows")
print(f"Transactions with NULL category_id: {df_txn_supermarket.filter(F.col('category_id').isNull()).count():,}")
print(f"Transactions with NULL region_name: {df_txn_supermarket.filter(F.col('region_name').isNull()).count():,}")

# Filter out rows without category mapping (cannot contribute to category breadth)
df_txn_supermarket = df_txn_supermarket.filter(F.col("category_id").isNotNull())

# --------------------------------------------------------------------------
# Primary region from last 90 days of supermarket transactions
# --------------------------------------------------------------------------
# Tie-breakers: higher spend, then alphabetical region_name for determinism.
w_region = Window.partitionBy("customer_id").orderBy(
    F.desc("region_txn_count"),
    F.desc("region_spend"),
    F.asc_nulls_last("region_name")
)

df_primary_region = (
    df_txn_supermarket
    .filter(F.col("transaction_date") >= F.lit(region_lookback_start))
    .groupBy("customer_id", "region_name")
    .agg(
        F.countDistinct("transaction_id").alias("region_txn_count"),
        F.sum("net_amount").alias("region_spend")
    )
    .withColumn("region_rank", F.row_number().over(w_region))
    .filter(F.col("region_rank") == 1)
    .select(
        "customer_id",
        F.coalesce(F.col("region_name"), F.lit("Unknown")).alias("region_name")
    )
)

print(f"\nCustomers with primary region from last 90 days: {df_primary_region.count():,}")
df_primary_region.show(5, truncate=False)

# --------------------------------------------------------------------------
# Compute monthly category aggregates per customer
# --------------------------------------------------------------------------

# Window for finding top category per customer-month
w_top_category = Window.partitionBy("customer_id", "year_month").orderBy(
    F.desc("cat_txn_count"),
    F.desc("cat_spend"),
    F.asc("category_id")
)

# Category frequency per customer-month
df_category_freq = (
    df_txn_supermarket
    .groupBy("customer_id", "year_month", "category_id", "category_name")
    .agg(
        F.countDistinct("transaction_id").alias("cat_txn_count"),
        F.sum("net_amount").alias("cat_spend")
    )
    .withColumn("cat_rank", F.row_number().over(w_top_category))
)

# Top category per customer-month
df_top_category = (
    df_category_freq
    .filter(F.col("cat_rank") == 1)
    .select(
        "customer_id",
        "year_month",
        F.col("category_id").alias("top_category_id"),
        F.col("category_name").alias("top_category_name")
    )
)

# Main monthly metrics at category level
df_monthly_breadth = (
    df_txn_supermarket
    .groupBy("customer_id", "year_month")
    .agg(
        F.countDistinct("category_id").alias("breadth_score"),
        F.sum("net_amount").alias("total_spend"),
        F.countDistinct("transaction_id").alias("visit_count")
    )
    .join(df_top_category, on=["customer_id", "year_month"], how="left")
    .orderBy("customer_id", "year_month")
)

# --------------------------------------------------------------------------
# Print summary statistics
# --------------------------------------------------------------------------
monthly_count = df_monthly_breadth.count()
print(f"\nMonthly breadth records: {monthly_count:,}")
print(f"Unique customers: {df_monthly_breadth.select('customer_id').distinct().count():,}")
print(f"Date range: {df_monthly_breadth.select(F.min('year_month')).first()[0]} to {df_monthly_breadth.select(F.max('year_month')).first()[0]}")

