# ============================================================================
# STEP 4G: MOMENTUM / SHAPE FEATURES FROM BREADTH TIME SERIES
# ============================================================================
# These 4 features capture the TEMPORAL SHAPE of decline — missing from the
# current feature set which only measures level and overall slope.
#
#   consecutive_decline_months : months in a row breadth has been falling
#                                (most directly predictive — event = 3 consec.)
#   last_month_breadth_change  : most recent month's signed change
#   breadth_acceleration       : 2nd diff — is decline speeding up?
#   pct_months_declining       : fraction of 5 MoM steps that were negative
# ============================================================================

sorted_months = sorted(event_months)   # 6 months in chronological order

# ── Pivot monthly breadth to pandas (one row per customer) ────────────────
df_bp_pd = df_breadth_pivot.toPandas()
for m in sorted_months:
    if m not in df_bp_pd.columns:
        df_bp_pd[m] = 0.0
df_bp_pd[sorted_months] = df_bp_pd[sorted_months].fillna(0.0)
df_bp_pd['customer_id'] = df_bp_pd['customer_id'].astype(str)

# ── Feature 1: consecutive_decline_months ─────────────────────────────────
def _consec_declines(row, months):
    count = 0
    for i in range(len(months) - 1, 0, -1):
        if row[months[i]] < row[months[i - 1]]:
            count += 1
        else:
            break
    return count

df_bp_pd['consecutive_decline_months'] = df_bp_pd.apply(
    _consec_declines, args=(sorted_months,), axis=1
)

# ── Feature 2: last_month_breadth_change ──────────────────────────────────
df_bp_pd['last_month_breadth_change'] = (
    df_bp_pd[sorted_months[-1]] - df_bp_pd[sorted_months[-2]]
)

# ── Feature 3: breadth_acceleration ──────────────────────────────────────
df_bp_pd['breadth_acceleration'] = (
    (df_bp_pd[sorted_months[-1]] - df_bp_pd[sorted_months[-2]]) -
    (df_bp_pd[sorted_months[-2]] - df_bp_pd[sorted_months[-3]])
)

# ── Feature 4: pct_months_declining ──────────────────────────────────────
decline_flags = [
    (df_bp_pd[sorted_months[i]] < df_bp_pd[sorted_months[i - 1]]).astype(float)
    for i in range(1, len(sorted_months))
]
df_bp_pd['pct_months_declining'] = sum(decline_flags) / len(decline_flags)

# ── Merge into df_model_data ──────────────────────────────────────────────
momentum_cols = [
    'customer_id',
    'consecutive_decline_months',
    'last_month_breadth_change',
    'breadth_acceleration',
    'pct_months_declining',
]
df_model_data['customer_id'] = df_model_data['customer_id'].astype(str)
df_model_data = df_model_data.merge(
    df_bp_pd[momentum_cols], on='customer_id', how='left'
)
df_model_data[momentum_cols[1:]] = df_model_data[momentum_cols[1:]].fillna(0)

print("Momentum features added:")
print(df_model_data[momentum_cols[1:]].describe().round(3))
print(f"\nconsecutive_decline_months distribution:")
print(df_model_data['consecutive_decline_months'].value_counts().sort_index())
print(f"\nEvent rate by consecutive_decline_months (key sanity check):")
print(df_model_data.groupby('consecutive_decline_months')['event_flag'].mean().round(3))
