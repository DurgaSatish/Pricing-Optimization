## Step 6: Scoring / Inference

This step applies the trained Cox model to all active customers, generating risk scores and assigning each customer to a risk tier for CRM prioritization.
# ============================================================================
# STEP 6: SCORING / INFERENCE
# ============================================================================
# Apply trained Cox model to all customers:
#   - Generate partial hazard scores (relative risk)
#   - Normalize to 0-100 scale
#   - Assign risk tiers: High (top 20%), Medium (20-50%), Low (bottom 50%)
# ============================================================================

# --------------------------------------------------------------------------
# Generate Partial Hazard Scores
# --------------------------------------------------------------------------
# IMPORTANT: cph was fitted on SCALED features (via _scaler in Step 5).
# We must pass the same scaled matrix for prediction — NOT the original values.
# The overflow in the previous run was caused by passing unscaled values.

# Rebuild the scaled scoring matrix from the clean model data
df_score_raw = df_model_data_clean[clean_feature_columns].copy()
# df_model_data_clean already has scaled values from Step 5 — use directly
df_score_raw = df_score_raw.replace([np.inf, -np.inf], np.nan).fillna(0)

# Use log partial hazard to avoid exp() overflow on extreme feature values
# log_partial_hazard = X * beta  (no exp applied, stays numerically stable)
log_partial_hazard = cph.predict_log_partial_hazard(df_score_raw)
df_model_data['log_partial_hazard'] = log_partial_hazard.values

# --------------------------------------------------------------------------
# Normalize log partial hazard to 0-100
# --------------------------------------------------------------------------
# Direction of log_partial_hazard depends on convergence path:
#   raw_concordance_index_ > 0.5 → higher LPH = higher risk (normal)
#   raw_concordance_index_ < 0.5 → lower  LPH = higher risk (inverted)
# raw_concordance is set in Step 5 and used here to pick the correct direction.
lph_min = df_model_data['log_partial_hazard'].replace([np.inf, -np.inf], np.nan).quantile(0.01)
lph_max = df_model_data['log_partial_hazard'].replace([np.inf, -np.inf], np.nan).quantile(0.99)

if raw_concordance < 0.5:
    # Inverted: lower LPH → score = 100 (highest risk)
    df_model_data['hazard_score'] = (
        (lph_max - df_model_data['log_partial_hazard'].clip(lph_min, lph_max))
        / (lph_max - lph_min) * 100
    ).round(1)
    print(f"Score direction: INVERTED (raw C={raw_concordance:.3f} < 0.5, effective C={1-raw_concordance:.3f})")
else:
    # Normal: higher LPH → score = 100 (highest risk)
    df_model_data['hazard_score'] = (
        (df_model_data['log_partial_hazard'].clip(lph_min, lph_max) - lph_min)
        / (lph_max - lph_min) * 100
    ).round(1)
    print(f"Score direction: NORMAL (raw C={raw_concordance:.3f} ≥ 0.5)")

# Keep partial_hazard column for compatibility
df_model_data['partial_hazard'] = df_model_data['log_partial_hazard']

# --------------------------------------------------------------------------
# Assign Risk Tiers
# --------------------------------------------------------------------------
# High Risk: top 20% (hazard_score >= 80th percentile)
# Medium Risk: 20-50% (hazard_score >= 50th and < 80th percentile)  
# Low Risk: bottom 50% (hazard_score < 50th percentile)

p80 = df_model_data['hazard_score'].quantile(0.80)
p50 = df_model_data['hazard_score'].quantile(0.50)

def assign_risk_tier(score):
    if score >= p80:
        return 'High Risk'
    elif score >= p50:
        return 'Medium Risk'
    else:
        return 'Low Risk'

df_model_data['risk_tier'] = df_model_data['hazard_score'].apply(assign_risk_tier)

# Sanity check: event rate should be highest in High Risk
print("\nSanity check — event rate by risk tier (High Risk should be highest):")
print(df_model_data.groupby('risk_tier')['event_flag'].mean().sort_values(ascending=False))

# --------------------------------------------------------------------------
# Summary Statistics
# --------------------------------------------------------------------------
print("="*60)
print("SCORING SUMMARY")
print("="*60)

print(f"\nTotal customers scored: {len(df_model_data):,}")
print(f"\nHazard Score Distribution:")
print(df_model_data['hazard_score'].describe())

print(f"\nRisk Tier Thresholds:")
print(f"  High Risk: score >= {p80:.1f} (top 20%)")
print(f"  Medium Risk: {p50:.1f} <= score < {p80:.1f} (20-50%)")
print(f"  Low Risk: score < {p50:.1f} (bottom 50%)")

print(f"\nRisk Tier Distribution:")
tier_counts = df_model_data['risk_tier'].value_counts()
for tier in ['High Risk', 'Medium Risk', 'Low Risk']:
    count = tier_counts.get(tier, 0)
    pct = count / len(df_model_data) * 100
    print(f"  {tier}: {count:,} ({pct:.1f}%)")

# Validate event rate by tier (High Risk should have highest event rate)
print(f"\nEvent Rate by Risk Tier (validation):")
event_by_tier = df_model_data.groupby('risk_tier')['event_flag'].mean().sort_values(ascending=False)
