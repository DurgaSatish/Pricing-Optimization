## Step 7: Clustering (Trajectory Segmentation)

This step segments customers into behavioral archetypes using KMeans clustering on their breadth time series. Each segment suggests a different intervention strategy.
# ============================================================================
# STEP 7: CLUSTERING (TRAJECTORY SEGMENTATION)
# ============================================================================
# Use KMeans (k=4) on breadth time series to identify behavioral archetypes:
#   - Gradual Consolidator: slow steady decline
#   - Sudden Dropper: sharp recent decline
#   - Stable Multi-Category: healthy, no action needed
#   - Recovering: was declining, now improving
# ============================================================================

# --------------------------------------------------------------------------
# 7A: Prepare clustering features (breadth time series in wide format)
# --------------------------------------------------------------------------

# Get the breadth columns from our pivot (these are the time series values)
cluster_feature_cols = [
    'breadth_slope',
    'breadth_peak',
    'breadth_current', 
    'breadth_drop_pct',
    'breadth_volatility',
    'months_since_peak'
]

# Prepare clustering data
df_cluster = df_model_data[['customer_id'] + cluster_feature_cols].copy()
df_cluster = df_cluster.replace([np.inf, -np.inf], np.nan).fillna(0)

# --------------------------------------------------------------------------
# 7B: Normalize features for clustering
# --------------------------------------------------------------------------
scaler = StandardScaler()
X_scaled = scaler.fit_transform(df_cluster[cluster_feature_cols])

print(f"Clustering on {X_scaled.shape[0]:,} customers with {X_scaled.shape[1]} features")

# --------------------------------------------------------------------------
# 7C: Fit KMeans with k=4
# --------------------------------------------------------------------------
kmeans = KMeans(n_clusters=4, random_state=42, n_init=10)
df_cluster['cluster'] = kmeans.fit_predict(X_scaled)

print(f"\nCluster sizes:")
print(df_cluster['cluster'].value_counts().sort_index())

# --------------------------------------------------------------------------
# 7D: Analyze cluster centroids to assign meaningful labels
# --------------------------------------------------------------------------

# Get cluster centroids (in original scale)
centroids_scaled = kmeans.cluster_centers_
centroids_original = scaler.inverse_transform(centroids_scaled)
centroids_df = pd.DataFrame(centroids_original, columns=cluster_feature_cols)
centroids_df['cluster'] = range(4)

print(f"\nCluster Centroids (original scale):")
print(centroids_df.round(2).to_string())

# --------------------------------------------------------------------------
# 7E: Assign segment labels based on centroid characteristics
# --------------------------------------------------------------------------
# Logic:
#   - Gradual Consolidator: negative slope, moderate drop, low volatility
#   - Sudden Dropper: negative slope, high drop, high volatility
#   - Stable Multi-Category: near-zero slope, low drop
#   - Recovering: positive slope or current > recent trend suggests improvement

def assign_segment_label(cluster_id, centroids_df):
    """Assign meaningful segment label based on centroid characteristics."""
    row = centroids_df[centroids_df['cluster'] == cluster_id].iloc[0]
    
    slope = row['breadth_slope']
    drop_pct = row['breadth_drop_pct']
    volatility = row['breadth_volatility']
    current = row['breadth_current']
    
    # Decision tree for segment assignment
    if slope > 0.1:  # Positive trend
        return 'Recovering'
    elif slope < -0.2 and drop_pct > 30:  # Strong negative trend + large drop
        if volatility > 1.5:
            return 'Sudden Dropper'
        else:
            return 'Gradual Consolidator'
    elif abs(slope) <= 0.1 and drop_pct < 20:  # Stable
        return 'Stable Multi-Category'
    elif slope < 0:  # Negative but not severe
        return 'Gradual Consolidator'
    else:
        return 'Stable Multi-Category'

# Create mapping from cluster to segment
cluster_to_segment = {}
for cluster_id in range(4):
    cluster_to_segment[cluster_id] = assign_segment_label(cluster_id, centroids_df)

print(f"\nCluster to Segment Mapping:")
for k, v in cluster_to_segment.items():
    print(f"  Cluster {k} -> {v}")

# If we have duplicate labels, disambiguate based on severity
label_counts = pd.Series(cluster_to_segment.values()).value_counts()
if label_counts.max() > 1:
    print("\nNote: Refining duplicate segment labels based on severity...")
    # Sort clusters by breadth_slope and reassign
    sorted_clusters = centroids_df.sort_values('breadth_slope')['cluster'].tolist()
    segment_labels = ['Sudden Dropper', 'Gradual Consolidator', 'Stable Multi-Category', 'Recovering']
    cluster_to_segment = dict(zip(sorted_clusters, segment_labels))
    print(f"Refined mapping: {cluster_to_segment}")

# Apply segment labels
df_cluster['segment'] = df_cluster['cluster'].map(cluster_to_segment)

# Merge segment back to main model data
df_model_data['segment'] = df_cluster['segment']

# --------------------------------------------------------------------------
# 7F: Summary by segment
# --------------------------------------------------------------------------
print(f"\n" + "="*60)
print("SEGMENT SUMMARY")
print("="*60)

segment_summary = df_model_data.groupby('segment').agg({
    'customer_id': 'count',
    'hazard_score': 'mean',
    'breadth_slope': 'mean',
    'breadth_drop_pct': 'mean',
    'avg_monthly_spend': 'mean',
    'event_flag': 'mean'
}).round(2)
segment_summary.columns = ['Count', 'Avg Hazard Score', 'Avg Breadth Slope', 
                           'Avg Drop %', 'Avg Monthly Spend', 'Event Rate']
print(segment_summary.to_string())

# Visualization
